rules_version = '2';

// ======================================================================
// TOJI PROTOCOL — Firestore security rules
//
// How to apply these: Firebase Console → Firestore Database →
// Rules tab → paste this file's contents → Publish.
// (Or via CLI: `firebase deploy --only firestore:rules` — see
// FIREBASE_SETUP.md for the full CLI setup.)
//
// Logic: every user's progress lives at users/{userId} where {userId}
// is their Firebase Auth uid. A signed-in user may read and write ONLY
// the document whose id matches their own uid — never anyone else's.
// Everything not explicitly matched below is denied by default, which
// is how Firestore rules work (deny-by-default).
// ======================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }
  }
}

